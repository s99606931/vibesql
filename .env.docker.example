# vibeSQL — docker compose env
# Copy to .env.docker (gitignored) and fill in the secret values.
#
#   cp .env.docker.example .env.docker
#
# DATABASE_URL is set by docker-compose.yml — do NOT override here.

# ── Required: AI provider ────────────────────────────────────────────────────
# vibeSQL needs at least one provider key for SQL generation + AI chat.
ANTHROPIC_API_KEY=sk-ant-xxxxx
# OPENAI_API_KEY=sk-xxxxx
# GOOGLE_AI_API_KEY=xxxxx

# ── Required: encryption + JWT ───────────────────────────────────────────────
# Connection passwords are AES-256-GCM encrypted at rest.
# JWT secret signs the vs-session cookie.
# Generate fresh values:
#   openssl rand -hex 32
CONNECTION_ENCRYPTION_KEY=replace_with_64_char_hex_from_openssl
JWT_SECRET=replace_with_64_char_hex_from_openssl

# ── Optional: host port overrides ────────────────────────────────────────────
# Used by docker-compose.yml — change if 3000/5432 are taken.
WEB_HOST_PORT=3000
POSTGRES_HOST_PORT=5432

# ── Optional: external base URL ──────────────────────────────────────────────
# Only matters if you put a reverse proxy in front of the container.
NEXT_PUBLIC_APP_URL=http://localhost:3000
