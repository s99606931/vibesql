# ─────────────────────────────────────────────────────────────────────────────
# vibeSQL — Environment Variables
# Copy to .env.local for local dev. Set these as Railway env vars in production.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database (optional — app runs in-memory without this) ─────────────────────
# Railway: add a PostgreSQL plugin, then copy the DATABASE_URL it provides
DATABASE_URL="postgresql://user:password@localhost:5432/vibesql"

# ── Security ──────────────────────────────────────────────────────────────────
# 64-char hex key for AES-256-GCM encryption of saved connection passwords
# Generate: openssl rand -hex 32
CONNECTION_ENCRYPTION_KEY=""

# ── AI Providers ──────────────────────────────────────────────────────────────
# At least one required for SQL generation and AI chat features
ANTHROPIC_API_KEY="sk-ant-..."
# OPENAI_API_KEY="sk-..."
# GOOGLE_AI_API_KEY="..."

# ── Auth (Clerk) ───────────────────────────────────────────────────────────────
# Without Clerk keys all requests run as "dev-user" (fine for self-hosted use)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/signin"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/workspace"

# ── App URL ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="https://your-app.up.railway.app"
